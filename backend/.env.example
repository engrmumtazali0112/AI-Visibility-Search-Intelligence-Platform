# AI provider (choose Anthropic and/or OpenAI - Anthropic is used by default in this codebase)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # not required unless you switch providers in app/agents/base.py

DATABASE_URL=sqlite:///dev.db
FLASK_ENV=development
SECRET_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173

# Optional: real search-volume/keyword data provider. If unset, a deterministic
# heuristic estimator is used instead (see app/utils/scoring.py for rationale).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
